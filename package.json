{
  "name": "chrome-cocopy",
  "version": "0.4.0",
  "private": true,
  "repository": "ssh://git@github.com/pokutuna/chrome-cocopy.git",
  "license": "MIT",
  "author": "pokutuna <mail@pokutuna.com>",
  "packageManager": "pnpm@10.12.2",
  "scripts": {
    "build": "vite build",
    "check": "gts check",
    "clean": "gts clean",
    "e2e": "playwright test",
    "pree2e": "pnpm run build",
    "fix": "gts fix",
    "prepare": "husky",
    "test": "jest",
    "posttest": "pnpm run check",
    "test-watch": "jest --watch",
    "update-gallery": "ts-node ./gallery/generate.ts",
    "validator": "ajv compile -s ./src/lib/function.schema.json -o ./src/lib/function.ajv.js",
    "watch": "vite build --watch",
    "zip": "pnpm run build && zip -r build-$(cat build/manifest.json | jq -r '.version').zip ./build"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "gts fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.3.1",
    "@fortawesome/free-solid-svg-icons": "7.3.1",
    "@fortawesome/react-fontawesome": "3.4.0",
    "ajv": "8.20.0",
    "chroma-js": "3.2.0",
    "jsx-runtime": "1.2.0",
    "lodash.debounce": "4.0.8",
    "mustache": "4.2.0",
    "prismjs": "1.30.0",
    "react": "19.2.7",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "react-simple-code-editor": "0.14.1",
    "styled-components": "6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chroma-js": "3.1.2",
    "@types/chrome": "0.2.2",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/lodash.debounce": "4.0.9",
    "@types/mustache": "4.2.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "ajv-cli": "5.0.0",
    "eslint": "9.39.5",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.7.0",
    "gts": "7.0.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.4.2",
    "jest-chrome": "0.8.0",
    "jest-environment-jsdom": "30.4.1",
    "jest-styled-components": "7.4.0",
    "js-yaml": "5.2.1",
    "lint-staged": "17.0.8",
    "rollup-plugin-license": "^3.7.1",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vite": "^8.1.5"
  },
  "engines": {
    "node": ">=24"
  }
}
