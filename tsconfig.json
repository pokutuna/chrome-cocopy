{
  "compilerOptions": {
    // Inlined from gts's tsconfig-google.json (previously extended via
    // ./node_modules/gts/tsconfig-google.json) now that gts has been removed.
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "pretty": true,
    "sourceMap": true,
    "stripInternal": true,
    "strict": true,
    "target": "ES2022",

    "lib": [
      "dom",
      "ES2020"
    ],
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "chrome",
      "vitest/globals",
      "node"
    ],
    "declaration": false,
    "composite": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./build"
  },
  "include": [
    "src/**/*",
    "gallery/**/*",
    "e2e/**/*",
    "scripts/**/*",
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ]
}
